__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
.ipynb_checkpoints/
.pytest_cache/

# Virtualenvs
venv/
env/
.venv/
.env

# Experiment trackers
mlruns/
wandb/

